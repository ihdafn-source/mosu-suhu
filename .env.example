# Example environment variables for local development
# Copy this file to `.env` and fill in the real values. DO NOT commit real secrets.

# Public / client keys used by the frontend
VITE_SUPABASE_URL=https://<project_ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Server / functions (required by Supabase Edge Functions)
# Set `SUPABASE_URL` to the same value as `VITE_SUPABASE_URL` (but without the `VITE_` prefix).
SUPABASE_URL=https://<project_ref>.supabase.co
# The service role key is a secret. Only set this for local function execution or server-side processes.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: local port for Supabase (if using supabase dev)
# SUPABASE_LOCAL_PORT=54322
VITE_SUPABASE_URL=https://blbdtgfvtnjucsbpwtex.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_Y0sDWVox8Eb1ijKQI2urxg_j5YMtLjH